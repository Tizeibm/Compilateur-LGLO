
// Déclarations et constantes
var score#
var message <-- 'Initialisation'#
const VERSION <-- 1.0#
v<--70#
const SEUIL <-- 50#

// Arithmétique complexe (Vérification des priorités)
// Teste : Parenthèses, Puissance, Division et Modulo
var calcul#
calcul <-- (10 + 5) * 2 ^ 3 #/// (4 - 1) % 2#
score <-- 100#

// Incrémentation et Décrémentation
score++#
--score#

// Entrées / Sorties avec chaînes complexes
ecrire('--- Debut du programme ---')#
ecrire('Veuillez saisir votre identifiant :')#
lire(score)#

// Structures conditionnelles imbriquées
si (score >= SEUIL et score <= 100) {
    ecrire('Resultat : Admis')#
    si (score == 100) {
        ecrire('Mention : Parfait')#
    } sinon {
        ecrire('Mention : Bien')#
    }
} sinonsi (score < SEUIL et score > 0) {
    ecrire('Resultat : Recale')#
} sinon {
    ecrire('Erreur : Score invalide')#
}

// Boucles (Tantque et Pour)
var i <-- 0#
tantque (i < 5) {
    ecrire('Tour de boucle tantque')#
    i <-- i + 1#
}

pour (var j <-- 1# j <= 3# j++) {
    ecrire('Iteration du pour')#
}

// Définition de fonctions et procédures
fonction multiplier(a, b) {
    var res <-- a * b#
    retourner res#
}

procedure formaterSortie(valeur, texte) {
    ecrire('Rapport :')#
    ecrire(texte)#
    ecrire(valeur)#
}

// Appels (Procédure seule et Fonction dans expression)
var total#
total <-- multiplier(10, 5) + 10#
formaterSortie(total, 'Calcul final termine')#

ecrire('--- Fin du test ---')#